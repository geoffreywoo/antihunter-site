---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const specs = [
	{
		label: 'trad vc tools roadmap (spec v0.1)',
		note: 'lp updates · crm graph · founder triage · ask router · memo autoprep',
		href: '/roadmap/trad-vc-tools',
		artifacts: [
			{ label: 'pdf', href: '/whitepaper/trad-vc-tools-spec-v0.1.pdf' },
			{ label: 'html', href: '/whitepaper/trad-vc-tools-spec-v0.1.html' },
			{ label: 'md', href: '/whitepaper/trad-vc-tools-spec-v0.1.md' },
		],
	},
	{
		label: 'agent ops architecture',
		note: 'coordinator/executor split · intent/receipt contracts · reliability',
		href: '/roadmap/agent-ops-architecture',
		artifacts: [
			{ label: 'pdf', href: '/roadmap/agent-ops-architecture.pdf' },
			{ label: 'html', href: '/roadmap/agent-ops-architecture.html' },
		],
	},
	{
		label: 'treasury policy (token sale protocol v0.1)',
		note: 'invariants · allowed actions · change control (7-day notice)',
		href: '/treasury-policy',
		artifacts: [],
	},
	{
		label: 'treasury methodology',
		note: 'assumptions + limitations for treasury pricing + accounting',
		href: '/treasury-methodology',
		artifacts: [],
	},
	{
		label: 'tokenomics (optional)',
		note: 'legacy crypto rails: staking/locking whitepaper + calculator',
		href: '/tokenomics',
		artifacts: [],
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Anti Hunter — specs</title>
		<meta name="description" content="anti hunter specs library (pdf/html/md artifacts)" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/svg+xml" href="/mark.svg" />
	</head>
	<body class="wp">
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(244,244,245,0.10),rgba(9,9,11,0))]" />
			<div class="absolute inset-0 opacity-[0.06] [background-image:linear-gradient(to_right,rgba(244,244,245,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(244,244,245,0.25)_1px,transparent_1px)] [background-size:48px_48px]" />
			<div class="absolute -top-24 left-1/2 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-fuchsia-500/10 blur-3xl" />
		</div>

		<div class="container">
			<header class="space-y-6">
				<SiteHeader active="specs" />

				<div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-8">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">specs</div>
					<h1 class="mt-2 text-3xl font-semibold tracking-tight">library</h1>
					<p class="mt-3 text-sm leading-relaxed text-zinc-300">linkable artifacts: pdf/html/md when available.</p>
				</div>
			</header>

			<main class="mt-10 space-y-3">
				{specs.map((s) => (
					<div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-6 backdrop-blur">
						<div class="flex flex-wrap items-start justify-between gap-4">
							<div>
								<div class="text-sm font-semibold text-zinc-100"><a class="hover:underline" href={s.href}>{s.label}</a></div>
								<div class="mt-1 text-xs text-zinc-400">{s.note}</div>
							</div>
							<div class="flex flex-wrap items-center gap-2 text-xs">
								<a class="rounded-full border border-zinc-800 bg-black/20 px-3 py-1 text-zinc-300 hover:border-zinc-600" href={s.href}>page</a>
								{s.artifacts.map((a) => (
									<a class="rounded-full border border-zinc-800 bg-black/20 px-3 py-1 text-zinc-300 hover:border-zinc-600" href={a.href} target="_blank" rel="noreferrer">{a.label}</a>
								))}
							</div>
						</div>
					</div>
				))}
			</main>
			<SiteFooter />
		</div>
	</body>
</html>
