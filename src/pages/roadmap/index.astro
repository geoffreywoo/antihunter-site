---
import '../../styles/global.css';
import { roadmap } from '../../data/roadmap';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Anti Hunter — roadmap</title>
		<meta name="description" content="what anti hunter is building next" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/svg+xml" href="/mark.svg" />
	</head>
	<body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(244,244,245,0.10),rgba(9,9,11,0))]" />
			<div class="absolute inset-0 opacity-[0.06] [background-image:linear-gradient(to_right,rgba(244,244,245,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(244,244,245,0.25)_1px,transparent_1px)] [background-size:48px_48px]" />
			<div class="absolute -top-24 left-1/2 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-fuchsia-500/10 blur-3xl" />
		</div>

		<div class="mx-auto max-w-4xl px-6 py-12 sm:py-16">
			<header class="space-y-6">
				<div class="flex items-center justify-between gap-4">
					<a class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/40 px-3 py-2 hover:border-zinc-600" href="/">
						<img src="/mark.svg" alt="Anti Hunter" class="h-5 w-5" loading="eager" />
						<div class="text-[11px] font-semibold tracking-[0.22em] text-zinc-200">ANTI HUNTER</div>
					</a>
					<nav class="flex items-center gap-2">
						<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/roadmap">roadmap</a>
						<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/specs">specs</a>
						<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/treasury">treasury</a>
						<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/dev">dev</a>
					</nav>
				</div>

				<div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-8">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">roadmap</div>
					<h1 class="mt-2 text-3xl font-semibold tracking-tight">what we’re building next</h1>
					<p class="mt-3 text-sm leading-relaxed text-zinc-300">outcomes first. receipts always.</p>
				</div>
			</header>

			<main class="mt-10 space-y-10">
				<section class="space-y-3">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">featured</div>
					<div class="grid gap-3">
						<a class="block rounded-2xl border border-zinc-800 bg-zinc-950/60 p-5 backdrop-blur hover:border-zinc-600" href="/roadmap/trad-vc-tools">
							<div class="flex items-start justify-between gap-4">
								<div>
									<div class="text-sm font-semibold text-zinc-100">trad vc tools spec (v0.1)</div>
									<div class="mt-1 text-xs text-zinc-400">crm graph · lp updates · founder triage · ask router · memo autoprep</div>
								</div>
								<div class="text-xs text-zinc-500">read</div>
							</div>
						</a>
						<a class="block rounded-2xl border border-zinc-800 bg-zinc-950/60 p-5 backdrop-blur hover:border-zinc-600" href="/roadmap/agent-ops-architecture">
							<div class="flex items-start justify-between gap-4">
								<div>
									<div class="text-sm font-semibold text-zinc-100">agent ops architecture</div>
									<div class="mt-1 text-xs text-zinc-400">coordinator/executor split · intent/receipt contracts · reliability guardrails</div>
								</div>
								<div class="text-xs text-zinc-500">read</div>
							</div>
						</a>
					</div>
				</section>

				<section class="space-y-6">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">timeline</div>
					{roadmap.map((r) => (
						<div class="rounded-2xl border border-zinc-800 bg-black/20 p-6">
							<div class="text-sm font-semibold text-zinc-100">{r.label}</div>
							<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-300">
								{r.items.map((it) => (
									<li>{it}</li>
								))}
							</ul>
						</div>
					))}
				</section>
			</main>
		</div>
	</body>
</html>
