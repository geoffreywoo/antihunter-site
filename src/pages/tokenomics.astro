---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const TERMS = [
	{ days: 30, weight: 1.0 },
	{ days: 60, weight: 1.4 },
	{ days: 90, weight: 1.9 },
	{ days: 120, weight: 2.5 },
];

const WEIGHT_CAP = 3.0;
const ROLLOVER_BONUS = 0.2;
const EARLY_EXIT_PENALTY_PCT = 25;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Anti Hunter Tokenomics — staking, locking, and buyback guardrails</title>
		<meta
			name="description"
			content="Anti Hunter tokenomics: staking and locking mechanics, rollover incentives, early exit penalties, and deterministic buyback guardrails."
		/>
		<link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
		<link rel="canonical" href="https://antihunter.com/tokenomics" />
		<meta property="og:title" content="Anti Hunter Tokenomics" />
		<meta property="og:description" content="Staking, locking, rollover incentives, and deterministic buyback guardrails." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://antihunter.com/tokenomics" />
		<meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
	</head>
	<body class="wp">
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(244,244,245,0.12),rgba(9,9,11,0))]" />
			<div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(to_right,rgba(244,244,245,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(244,244,245,0.25)_1px,transparent_1px)] [background-size:48px_48px]" />
			<div class="absolute -top-24 left-1/2 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-fuchsia-500/10 blur-3xl" />
		</div>

		<div class="container">
			<header class="space-y-6">
				<SiteHeader subtitle="legacy crypto rails" />
				<div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-10">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">Tokenomics</div>
					<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">staking / locking — the terms</h1>
					<p class="mt-4 max-w-2xl text-sm leading-relaxed text-zinc-300">
						plain-English view of the staking/locking spec. paper hands subsidize diamond hands.
						<span class="text-zinc-400"> not financial advice. verify against the contract + whitepaper.</span>
					</p>
					<div class="mt-6 flex flex-wrap gap-3">
						<a class="rounded-xl bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 shadow hover:bg-white" href="/whitepaper/staking-locking-v0.2.1.pdf" target="_blank" rel="noreferrer">
							Whitepaper PDF (v0.2.1)
						</a>
						<a class="rounded-xl border border-zinc-700 bg-zinc-900/30 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-500" href="/whitepaper/staking-locking-v0.2.1.html" target="_blank" rel="noreferrer">
							Whitepaper HTML
						</a>
						<a class="rounded-xl border border-sky-500/50 bg-sky-500/10 px-5 py-2.5 text-sm font-semibold text-sky-100 hover:border-sky-400" href="/whitepaper/staking-implementation-spec-v0.1.pdf" target="_blank" rel="noreferrer">
							Implementation Spec PDF (v0.1)
						</a>
						<a class="rounded-xl border border-zinc-700 bg-zinc-900/30 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-500" href="/whitepaper/staking-implementation-spec-v0.1.html" target="_blank" rel="noreferrer">
							Implementation Spec HTML
						</a>
					</div>
				</div>
			</header>

			<main class="mt-12 space-y-14">
				

				<section class="space-y-6">
					<div class="flex flex-wrap items-end justify-between gap-3">
						<h2 class="text-xl font-semibold">Lock terms and bonus weights</h2>
						<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">weights ≠ APY</div>
					</div>
					<div class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
						<div class="overflow-x-auto">
							<table class="min-w-full text-left text-sm">
								<thead class="text-xs uppercase tracking-[0.18em] text-zinc-500">
									<tr>
										<th class="py-2 pr-4">Term</th>
										<th class="py-2 pr-4">Base weight</th>
										<th class="py-2">Notes</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-zinc-800/70 text-zinc-200">
									{TERMS.map((t) => (
										<tr>
											<td class="py-3 pr-4 font-medium">{t.days} days</td>
											<td class="py-3 pr-4">{t.weight.toFixed(1)}×</td>
											<td class="py-3 text-zinc-400">Share of Rewards Pool emissions is proportional to your effective weight.</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
						<div class="mt-4 text-xs leading-relaxed text-zinc-500">
							Rollover incentive: re-lock within ~24h of maturity → <strong>+{ROLLOVER_BONUS.toFixed(1)}×</strong> (next term only). Cap: <strong>{WEIGHT_CAP.toFixed(1)}×</strong> effective weight.
						</div>
					</div>
				</section>

				<section class="space-y-6">
					<h2 class="text-xl font-semibold">Early exit penalty</h2>
					<div class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
						<p class="text-sm leading-relaxed text-zinc-300">
							You can exit early, but you pay a <strong>{EARLY_EXIT_PENALTY_PCT}% principal penalty</strong>.
							<span class="text-zinc-400"> Penalties route to the Rewards Pool (paper hands subsidize diamond hands).</span>
						</p>
						<div class="mt-4 text-xs leading-relaxed text-zinc-500">
							Implementation note: exact mechanics are defined by the contract/whitepaper; this page is a UX explainer.
						</div>
					</div>
				</section>

				<section class="space-y-6">
					<div class="flex flex-wrap items-end justify-between gap-3">
						<h2 class="text-xl font-semibold">Lock weight calculator</h2>
						<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">simple + transparent</div>
					</div>
					<div class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
						<div class="grid gap-5 sm:grid-cols-2">
							<div class="space-y-3">
								<label class="block text-xs uppercase tracking-[0.22em] text-zinc-500">Amount ($ANTIHUNTER)</label>
								<input id="calc-amount" type="number" min="0" step="any" value="1000000" class="w-full rounded-xl border border-zinc-800 bg-black/30 px-4 py-3 text-sm text-zinc-100 outline-none focus:border-zinc-600" />

								<label class="mt-4 block text-xs uppercase tracking-[0.22em] text-zinc-500">Term</label>
								<select id="calc-term" class="w-full rounded-xl border border-zinc-800 bg-black/30 px-4 py-3 text-sm text-zinc-100 outline-none focus:border-zinc-600">
									{TERMS.map((t) => (
										<option value={t.days}>{t.days} days ({t.weight.toFixed(1)}×)</option>
									))}
								</select>

								<label class="mt-4 flex items-center gap-3 text-sm text-zinc-300">
									<input id="calc-rollover" type="checkbox" class="h-4 w-4 rounded border-zinc-700 bg-black/30" />
									Rollover bonus (+{ROLLOVER_BONUS.toFixed(1)}× next term only)
								</label>
							</div>

							<div class="space-y-4">
								<div class="rounded-xl border border-zinc-800 bg-black/20 p-4">
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">Effective weight</div>
									<div id="calc-weight" class="mt-2 text-2xl font-semibold">—</div>
									<div class="mt-2 text-xs text-zinc-500">Cap: {WEIGHT_CAP.toFixed(1)}×</div>
								</div>

								<div class="rounded-xl border border-zinc-800 bg-black/20 p-4">
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">Weight units (amount × weight)</div>
									<div id="calc-units" class="mt-2 text-xl font-semibold">—</div>
									<div class="mt-2 text-xs text-zinc-500">Your share of emissions is proportional to weight units.</div>
								</div>

								<div class="rounded-xl border border-zinc-800 bg-black/20 p-4">
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">If you exit early</div>
									<div id="calc-penalty" class="mt-2 text-sm text-zinc-300">—</div>
								</div>
							</div>
						</div>

						<div class="mt-5 text-xs leading-relaxed text-zinc-500">
							This calculator intentionally avoids promising APY.
							Rewards can be 0; emissions depend on system activity and governance.
						</div>
					</div>
				</section>

				<script type="module">
					const TERMS = new Map([
						[30, 1.0],
						[60, 1.4],
						[90, 1.9],
						[120, 2.5],
					]);
					const WEIGHT_CAP = 3.0;
					const ROLLOVER_BONUS = 0.2;
					const EARLY_EXIT_PENALTY_PCT = 25;

					const amountEl = document.getElementById('calc-amount');
					const termEl = document.getElementById('calc-term');
					const rolloverEl = document.getElementById('calc-rollover');
					const weightEl = document.getElementById('calc-weight');
					const unitsEl = document.getElementById('calc-units');
					const penaltyEl = document.getElementById('calc-penalty');

					const fmt = (n, dp = 2) => (Number.isFinite(n) ? n.toLocaleString(undefined, { maximumFractionDigits: dp }) : '—');

					function recalc() {
						const amt = Number(amountEl.value);
						const days = Number(termEl.value);
						const base = TERMS.get(days) ?? 1.0;
						const rollover = rolloverEl.checked ? ROLLOVER_BONUS : 0;
						const eff = Math.min(WEIGHT_CAP, base + rollover);
						const units = Number.isFinite(amt) ? amt * eff : NaN;
						const penalty = Number.isFinite(amt) ? (amt * EARLY_EXIT_PENALTY_PCT) / 100 : NaN;
						const receive = Number.isFinite(amt) ? amt - penalty : NaN;

						weightEl.textContent = `${eff.toFixed(1)}×`;
						unitsEl.textContent = fmt(units, 2);
						penaltyEl.innerHTML = Number.isFinite(amt)
							? `Penalty: <strong>${fmt(penalty, 2)}</strong> $ANTIHUNTER · You receive: <strong>${fmt(receive, 2)}</strong> $ANTIHUNTER`
							: '—';
					}

					amountEl.addEventListener('input', recalc);
					termEl.addEventListener('change', recalc);
					rolloverEl.addEventListener('change', recalc);
					recalc();
				</script>
			</main>

			<footer class="mt-16 border-t border-zinc-900/80 pt-10 text-sm text-zinc-500">
				<div class="flex flex-wrap items-center justify-between gap-3">
					<div>© {new Date().getFullYear()} Anti Hunter</div>
					<div class="flex items-center gap-4">
						<a class="hover:text-zinc-300" href="/">Home</a>
						<a class="hover:text-zinc-300" href="/treasury-methodology">Treasury methodology</a>
						<a class="hover:text-zinc-300" href="https://x.com/antihunterai" target="_blank" rel="noreferrer">X</a>
					</div>
				</div>
			</footer>
			<SiteFooter />
		</div>
	</body>
</html>
