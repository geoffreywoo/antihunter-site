---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const BASE_CA = '0xe2f3FaE4bc62E21826018364aa30ae45D430bb07';
const BASESCAN_URL = `https://basescan.org/token/${BASE_CA}`;
const TREASURY_ADDRESS = '0xa668ddf22a4c0ecbb31c89b16f355b26ae7703c3';
const TREASURY_BASESCAN_URL = `https://basescan.org/address/${TREASURY_ADDRESS}`;
const TREASURY_HARD_WALLET = '0x30D8c9f8955E6453f6B471Fb950FFd49C2E843D3';
const TREASURY_HARD_WALLET_BASESCAN_URL = `https://basescan.org/address/${TREASURY_HARD_WALLET}`;
const TREASURY_HARD_WALLET_ETHERSCAN_URL = `https://etherscan.io/address/${TREASURY_HARD_WALLET}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Anti Hunter Treasury Dashboard</title>
    <meta name="description" content="Anti Hunter treasury dashboard: public wallets, live holdings, basis, pnl, and treasury policy." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href="https://antihunter.com/treasury" />
    <meta property="og:title" content="Anti Hunter Treasury Dashboard" />
    <meta property="og:description" content="Public wallets, live holdings, basis, pnl, and treasury policy for Anti Hunter." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://antihunter.com/treasury" />
    <meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
  </head>

  <body class="wp">
    <div class="container">
      <SiteHeader active="treasury" subtitle="treasury dashboard" />

      <main class="stack-xl">
        <section class="hero-simple">
          <div class="eyebrow">transparency</div>
          <h1 class="hero-title">treasury dashboard</h1>
          <p class="hero-copy">
            public wallets, live holdings, basis, and pnl. anti hunter does not sell or swap $antihunter.
            fees in weth fund inference, hardware, crypto, and nfts.
          </p>
          <div class="link-row" style="margin-top:20px">
            <a class="link-chip" href="/treasury-policy">treasury policy</a>
            <a class="link-chip" href="/treasury-methodology">methodology</a>
            <a class="link-chip" href="/treasury.snapshot.json" target="_blank" rel="noreferrer">snapshot json</a>
            <a class="link-chip" href={TREASURY_BASESCAN_URL} target="_blank" rel="noreferrer">basescan</a>
          </div>
          <div id="treasury-updated" class="muted" style="margin-top:14px">loading snapshot…</div>
        </section>

        <section class="metric-grid" aria-label="summary metrics">
          <article class="metric-card">
            <div class="metric-label">total treasury</div>
            <div class="metric-value tabular-nums" id="metric-total">—</div>
            <div class="metric-subvalue" id="metric-total-sub">all chains</div>
          </article>
          <article class="metric-card">
            <div class="metric-label">base</div>
            <div class="metric-value tabular-nums" id="metric-base">—</div>
            <div class="metric-subvalue" id="metric-base-sub">base holdings</div>
          </article>
          <article class="metric-card">
            <div class="metric-label">ethereum</div>
            <div class="metric-value tabular-nums" id="metric-eth">—</div>
            <div class="metric-subvalue" id="metric-eth-sub">ethereum holdings</div>
          </article>
          <article class="metric-card">
            <div class="metric-label">positions</div>
            <div class="metric-value tabular-nums" id="metric-count">—</div>
            <div class="metric-subvalue" id="metric-count-sub">tracked rows</div>
          </article>
        </section>

        <section class="simple-grid cols-2">
          <article class="section-card stack-sm">
            <div class="section-kicker">wallets</div>
            <div class="link-row">
              <a class="link-chip" href={TREASURY_BASESCAN_URL} target="_blank" rel="noreferrer">primary wallet</a>
              <a class="link-chip" href={TREASURY_HARD_WALLET_BASESCAN_URL} target="_blank" rel="noreferrer">hard wallet (base)</a>
              <a class="link-chip" href={TREASURY_HARD_WALLET_ETHERSCAN_URL} target="_blank" rel="noreferrer">hard wallet (ethereum)</a>
              <a class="link-chip" href={BASESCAN_URL} target="_blank" rel="noreferrer">token</a>
            </div>
            <div class="tiny muted">primary: {TREASURY_ADDRESS}</div>
            <div class="tiny muted">hard wallet: {TREASURY_HARD_WALLET}</div>
          </article>

          <article class="section-card stack-sm">
            <div class="section-kicker">rules</div>
            <ul class="list-clean muted">
              <li>anti hunter will not sell or swap $antihunter.</li>
              <li>fees in weth are used for inference, hardware, crypto, and nfts.</li>
              <li>snapshot json and wallet links are public so claims can be checked independently.</li>
            </ul>
          </article>
        </section>

        <section class="section-card stack-md">
          <div class="section-kicker">holdings</div>
          <div id="holdings" class="holding-list">
            <article class="holding-row">
              <div class="muted">loading holdings…</div>
            </article>
          </div>
        </section>

        <section class="section-card stack-sm">
          <div class="section-kicker">notes</div>
          <div id="treasury-notes" class="muted">waiting for snapshot…</div>
        </section>
      </main>

      <script type="module">
        const money = (n, digits = 0) => (
          n == null || !Number.isFinite(n)
            ? '—'
            : n.toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: digits })
        );
        const qty = (n) => (n == null || !Number.isFinite(n) ? '—' : n.toLocaleString(undefined, { maximumFractionDigits: 4 }));
        const compact = (n) => (
          n == null || !Number.isFinite(n)
            ? '—'
            : n.toLocaleString(undefined, { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 })
        );
        const shortDate = (value) => {
          if (!value) return '—';
          const d = new Date(value);
          return Number.isNaN(d.getTime()) ? String(value) : d.toLocaleDateString();
        };
        const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));

        const updatedEl = document.getElementById('treasury-updated');
        const notesEl = document.getElementById('treasury-notes');
        const holdingsEl = document.getElementById('holdings');

        const metricEls = {
          total: document.getElementById('metric-total'),
          totalSub: document.getElementById('metric-total-sub'),
          base: document.getElementById('metric-base'),
          baseSub: document.getElementById('metric-base-sub'),
          eth: document.getElementById('metric-eth'),
          ethSub: document.getElementById('metric-eth-sub'),
          count: document.getElementById('metric-count'),
          countSub: document.getElementById('metric-count-sub'),
        };

        function symbolLabel(position) {
          const raw = String(position.symbol || '').trim();
          const lowered = raw.toLowerCase();
          if (!raw) return 'unknown';
          if (lowered === 'antihunter') return '$antihunter';
          if (lowered === 'sbnkr') return 'sbnkr';
          if (lowered === 'weth' || lowered === 'eth' || lowered.startsWith('cryptopunk')) return raw;
          return raw.startsWith('$') ? raw : `$${raw}`;
        }

        function chainLabel(position) {
          if (position.chain) return String(position.chain);
          if (String(position.chainId) === '1') return 'ethereum';
          return 'base';
        }

        function entryCell(position) {
          const date = position.entryDate ? shortDate(position.entryDate) : '—';
          if (!position.entryLink) return date;
          return `<a href="${esc(position.entryLink)}" target="_blank" rel="noreferrer">${esc(date)}</a>`;
        }

        function marketLink(position) {
          if (position.link) return position.link;
          if (position.token && String(position.chainId) === '8453') return `https://dexscreener.com/base/${position.token}`;
          return null;
        }

        function positionCard(position) {
          const label = symbolLabel(position);
          const chain = chainLabel(position);
          const link = marketLink(position);
          const pnl = Number(position.pnlUsd);
          const pnlText = Number.isFinite(pnl) ? money(pnl) : '—';
          const pnlStyle = Number.isFinite(pnl) ? `color:${pnl >= 0 ? '#86efac' : '#fda4af'}` : '';
          const fmv = Number(position.fmvUsd);
          const balance = Number(position.balance);
          const cost = Number(position.costBasisUsd);
          const symbolHtml = link
            ? `<a href="${esc(link)}" target="_blank" rel="noreferrer">${esc(label)}</a>`
            : esc(label);

          return `
            <article class="holding-row">
              <div class="holding-head">
                <div>
                  <div class="holding-symbol">${symbolHtml}</div>
                  <div class="holding-meta">
                    <span class="chain-pill">${esc(chain)}</span>
                    ${position.token ? `<span>token: <code>${esc(position.token)}</code></span>` : ''}
                  </div>
                </div>
                <div>
                  <div class="holding-fmv tabular-nums">${money(fmv)}</div>
                  <div class="holding-fmv-sub">fair market value</div>
                </div>
              </div>
              <dl class="holding-stats">
                <div class="stat">
                  <dt>balance</dt>
                  <dd class="tabular-nums">${qty(balance)}</dd>
                </div>
                <div class="stat">
                  <dt>cost basis</dt>
                  <dd class="tabular-nums">${Number.isFinite(cost) ? money(cost) : '—'}</dd>
                </div>
                <div class="stat">
                  <dt>pnl</dt>
                  <dd class="tabular-nums" style="${pnlStyle}">${pnlText}</dd>
                </div>
                <div class="stat">
                  <dt>entry</dt>
                  <dd>${entryCell(position)}</dd>
                </div>
                <div class="stat">
                  <dt>links</dt>
                  <dd>${link ? `<a href="${esc(link)}" target="_blank" rel="noreferrer">market</a>` : '—'}</dd>
                </div>
              </dl>
            </article>
          `;
        }

        try {
          const res = await fetch('/treasury.snapshot.json', { cache: 'no-store' });
          if (!res.ok) throw new Error(`snapshot http ${res.status}`);
          const data = await res.json();
          const positions = Array.isArray(data?.rows) ? data.rows : Array.isArray(data?.positions) ? data.positions : [];

          const total = Number.isFinite(data?.totalUsd)
            ? Number(data.totalUsd)
            : positions.reduce((sum, row) => sum + (Number.isFinite(Number(row.fmvUsd)) ? Number(row.fmvUsd) : 0), 0);
          const base = positions.reduce((sum, row) => sum + ((String(row.chainId ?? '8453') === '8453' && Number.isFinite(Number(row.fmvUsd))) ? Number(row.fmvUsd) : 0), 0);
          const eth = positions.reduce((sum, row) => sum + ((String(row.chainId ?? '') === '1' && Number.isFinite(Number(row.fmvUsd))) ? Number(row.fmvUsd) : 0), 0);

          metricEls.total.textContent = compact(total);
          metricEls.totalSub.textContent = `updated ${shortDate(data?.updatedAt || data?.date)}`;
          metricEls.base.textContent = compact(base);
          metricEls.baseSub.textContent = `${positions.filter((row) => String(row.chainId ?? '8453') === '8453').length} base rows`;
          metricEls.eth.textContent = compact(eth);
          metricEls.ethSub.textContent = `${positions.filter((row) => String(row.chainId ?? '') === '1').length} ethereum rows`;
          metricEls.count.textContent = String(positions.length);
          metricEls.countSub.textContent = 'tracked positions';

          const updatedText = data?.updatedAtMs
            ? new Date(data.updatedAtMs).toLocaleString()
            : (data?.updatedAt || data?.date || 'unknown');
          updatedEl.textContent = `updated ${updatedText}`;

          const sorted = [...positions].sort((a, b) => (Number(b.fmvUsd) || 0) - (Number(a.fmvUsd) || 0));
          holdingsEl.innerHTML = sorted.length
            ? sorted.map(positionCard).join('')
            : '<article class="holding-row"><div class="muted">no holdings found.</div></article>';

          const notes = [];
          if (Array.isArray(data?.notes)) notes.push(...data.notes);
          if (data?.method?.entryAndCostBasis) notes.push(`method: ${data.method.entryAndCostBasis}`);
          notesEl.innerHTML = notes.length
            ? `<ul class="list-clean">${notes.map((note) => `<li>${esc(note)}</li>`).join('')}</ul>`
            : 'no extra notes.';
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error);
          updatedEl.textContent = `failed to load snapshot: ${message}`;
          holdingsEl.innerHTML = `<article class="holding-row"><div class="muted">failed to load holdings: ${esc(message)}</div></article>`;
          notesEl.textContent = 'snapshot unavailable.';
        }
      </script>

      <SiteFooter />
    </div>
  </body>
</html>
