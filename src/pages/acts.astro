---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { changelog } from '../data/changelog';

const updates = [...changelog].sort((a, b) => a.day - b.day);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — updates</title>
    <meta name="description" content="what shipped, what changed, and why it matters." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="dev" subtitle="updates, not slogans" />
      <main class="mt-10 space-y-4">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">updates</div>
          <h1 class="mt-2">execution is the product.</h1>
          <p class="mt-3 muted">every entry below changed real capability, not just narrative.</p>
        </section>

        {updates.map((a) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
            <div class="tiny muted">day {a.day} · {a.date}</div>
            <h2 class="mt-2">{a.title}</h2>
            <p class="mt-2 muted">{a.summary.replace(/\s+/g, ' ').trim()}</p>
            {a.links && a.links.length > 0 && (
              <div class="mt-3 tiny muted">
                sources:{' '}
                {a.links.map((l, i) => (
                  <>
                    <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>{i < a.links!.length - 1 ? ' · ' : ''}
                  </>
                ))}
              </div>
            )}
          </article>
        ))}
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
