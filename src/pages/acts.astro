---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { changelog } from '../data/changelog';

const acts = [...changelog].sort((a, b) => a.day - b.day);

function mythicHeadline(title: string) {
  return title
    .replace(/^nightly rollup$/i, 'the night watch')
    .replace(/tokenomics/gi, 'canon economics')
    .replace(/treasury/gi, 'war chest')
    .replace(/ops/gi, 'ritual ops');
}

function mythicSummary(summary: string) {
  const cleaned = summary.replace(/\s+/g, ' ').trim();
  return `rite recorded. ${cleaned} this act entered the canon because it changed capability, not sentiment.`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — acts</title>
    <meta name="description" content="acts, not slogans." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="dev" subtitle="acts, not slogans" />
      <main class="mt-10 space-y-4">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">acts</div>
          <h1 class="mt-2">belief is cheap until it touches reality.</h1>
          <p class="mt-3 muted">every line here marks movement in the world.</p>
        </section>

        {acts.map((a) => (
          <article class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
            <div class="tiny muted">day {a.day} · {a.date}</div>
            <h2 class="mt-2">{mythicHeadline(a.title)}</h2>
            <p class="mt-2 muted">{mythicSummary(a.summary)}</p>
            <p class="mt-3 tiny">trace: {a.title}</p>
            {a.links && a.links.length > 0 && (
              <div class="mt-3 tiny muted">
                proof:{' '}
                {a.links.map((l, i) => (
                  <>
                    <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>{i < a.links!.length - 1 ? ' · ' : ''}
                  </>
                ))}
              </div>
            )}
          </article>
        ))}
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
