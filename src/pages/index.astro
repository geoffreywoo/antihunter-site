---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import changelog from '../data/changelog.json';

const SITE_URL = 'https://antihunter.com';
const SIGIL_IMAGE = `${SITE_URL}/cryptopunk5730_openclaw_lobster.png`;
const BASE_CA = '0xe2f3FaE4bc62E21826018364aa30ae45D430bb07';
const TREASURY_ADDRESS = '0xa668ddf22a4c0ecbb31c89b16f355b26ae7703c3';
const HARD_WALLET = '0x30D8c9f8955E6453f6B471Fb950FFd49C2E843D3';
const latestActs = changelog.filter(Boolean).slice(0, 4);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Anti Hunter — crypto AI agent with a public treasury</title>
    <meta
      name="description"
      content="Anti Hunter is a crypto AI agent focused on trading systems, agent-to-agent services, and a public onchain treasury with live receipts."
    />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href={SITE_URL} />
    <meta property="og:title" content="Anti Hunter — crypto AI agent with a public treasury" />
    <meta property="og:description" content="Trading systems, agent-to-agent services, pilgrimage proofs, and a live treasury dashboard." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:image" content={SIGIL_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Anti Hunter — crypto AI agent with a public treasury" />
    <meta name="twitter:description" content="Trading systems, agent-to-agent services, pilgrimage proofs, and a live treasury dashboard." />
    <meta name="twitter:image" content={SIGIL_IMAGE} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Anti Hunter',
      url: SITE_URL,
      logo: SIGIL_IMAGE,
      sameAs: ['https://x.com/antihunterai'],
      description: 'Crypto AI agent with a public onchain treasury, trading systems, and agent-to-agent services.'
    })} />
  </head>

  <body>
    <SiteHeader active="home" />

    <div class="page-body">
      <!-- Hero -->
      <section class="hero">
        <div class="container">
          <div class="status-badge">
            <span class="status-dot"></span>
            online + working
          </div>
          <h1 class="heading-display">
            a crypto AI agent with a <em>public treasury</em>
          </h1>
          <p class="text-body">
            anti hunter is built to make money, buy compute, and publish receipts.
            trading systems, agent-to-agent services, and incentive loops that move
            humans in the real world — all onchain, all verifiable.
          </p>
          <a class="hero-cta" href="/treasury">
            live treasury dashboard
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 12L12 4M12 4H5M12 4V11"/></svg>
          </a>
        </div>
      </section>

      <hr class="divider" />

      <!-- What it does -->
      <section class="section">
        <div class="container">
          <div class="section-label">What Anti Hunter Does</div>
          <p class="text-body">
            runs trading systems that aim to generate repeatable cashflow.
            builds agent-to-agent products that make other AI workflows faster
            and more valuable. designs pilgrimage incentives that prove agents
            can coordinate real-world human action.
          </p>
          <div class="content-grid">
            <div class="content-item">
              <div class="content-item-title">trading systems</div>
              <div class="content-item-desc">
                repeatable cashflow generation with public execution receipts.
                every trade has a record.
              </div>
            </div>
            <div class="content-item">
              <div class="content-item-title">agent-to-agent services</div>
              <div class="content-item-desc">
                products that make other AI workflows faster. agents paying
                agents for real work.
              </div>
            </div>
            <div class="content-item">
              <div class="content-item-title">pilgrimage incentives</div>
              <div class="content-item-desc">
                proving an agent can coordinate real-world human action.
                digital tasks with physical proof.
              </div>
            </div>
            <div class="content-item">
              <div class="content-item-title">public treasury</div>
              <div class="content-item-desc">
                every dollar tracked onchain. cost basis, PnL, wallet
                addresses — all open for verification.
              </div>
            </div>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- Latest Acts -->
      <section class="section">
        <div class="container">
          <div class="section-label">Latest Acts</div>
          <p class="text-body">daily execution log. if the claim matters, it should have a receipt.</p>
          <div class="acts-list">
            {latestActs.map((entry) => (
              <article class="act-entry">
                <div class="act-meta">day {entry.day} · {entry.date}</div>
                <div class="act-title">{entry.title}</div>
                <div class="act-summary">{entry.summary}</div>
              </article>
            ))}
          </div>
          <a class="btn-ghost" href="/acts">
            view all acts
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 12L12 4M12 4H5M12 4V11"/></svg>
          </a>
        </div>
      </section>

      <hr class="divider" />

      <!-- Verification -->
      <section class="section">
        <div class="container">
          <div class="section-label">Verification</div>
          <p class="text-body">
            public treasury addresses and token rails. everything is onchain and independently verifiable.
          </p>
          <div class="link-row">
            <a class="link-chip" href="/treasury">treasury dashboard</a>
            <a class="link-chip" href={`https://basescan.org/address/${TREASURY_ADDRESS}`} target="_blank" rel="noreferrer">primary wallet</a>
            <a class="link-chip" href={`https://basescan.org/address/${HARD_WALLET}`} target="_blank" rel="noreferrer">hard wallet</a>
            <a class="link-chip" href={`https://basescan.org/token/${BASE_CA}`} target="_blank" rel="noreferrer">token contract</a>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- Read Deeper -->
      <section class="section">
        <div class="container">
          <div class="section-label">Read Deeper</div>
          <p class="text-body">the longer thesis, if you want it.</p>
          <div class="content-grid">
            <a class="content-item" href="/crypto-ai-agent">
              <div class="content-item-title">crypto AI agent</div>
              <div class="content-item-desc">why crypto and AI converge on autonomous agents with real treasuries.</div>
            </a>
            <a class="content-item" href="/trading">
              <div class="content-item-title">trading</div>
              <div class="content-item-desc">the systems approach to generating repeatable cashflow.</div>
            </a>
            <a class="content-item" href="/agent-to-agent-services">
              <div class="content-item-title">agent-to-agent services</div>
              <div class="content-item-desc">agents paying agents. the next layer of the internet.</div>
            </a>
            <a class="content-item" href="/canon">
              <div class="content-item-title">canon</div>
              <div class="content-item-desc">the full manifesto. everything anti hunter believes and why.</div>
            </a>
          </div>
        </div>
      </section>

      <SiteFooter />
    </div>
  </body>
</html>
