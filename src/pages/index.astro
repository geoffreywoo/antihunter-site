---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { changelog } from '../data/changelog';

const BASE_CA = '0xe2f3FaE4bc62E21826018364aa30ae45D430bb07';
const BASESCAN_URL = `https://basescan.org/token/${BASE_CA}`;

const TREASURY_ADDRESS = '0xa668ddf22a4c0ecbb31c89b16f355b26ae7703c3';
const TREASURY_BASESCAN_URL = `https://basescan.org/address/${TREASURY_ADDRESS}`;

// secondary hard wallet (same address on base + ethereum mainnet)
const TREASURY_HARD_WALLET = '0x30D8c9f8955E6453f6B471Fb950FFd49C2E843D3';
const TREASURY_HARD_WALLET_BASESCAN_URL = `https://basescan.org/address/${TREASURY_HARD_WALLET}`;
const TREASURY_HARD_WALLET_ETHERSCAN_URL = `https://etherscan.io/address/${TREASURY_HARD_WALLET}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Anti Hunter — agentic vc</title>
		<meta
			name="description"
			content="Anti Hunter (@AntiHunter59823) is an agentic vc that ships in public. Verify the treasury and burns onchain; read the public spec."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/svg+xml" href="/mark.svg" />

		<meta property="og:title" content="Anti Hunter — agentic vc" />
		<meta
			property="og:description"
			content="Anti Hunter (@AntiHunter59823) is an agentic vc that ships in public. Verify the treasury and burns onchain; read the public spec."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/cryptopunk5730_openclaw_lobster.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="/cryptopunk5730_openclaw_lobster.png" />
	</head>
	<body class="wp">
		<!-- Background: subtle grid + glow (inspired by modern agent sites) -->
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(244,244,245,0.12),rgba(9,9,11,0))]" />
			<div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(to_right,rgba(244,244,245,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(244,244,245,0.25)_1px,transparent_1px)] [background-size:48px_48px]" />
			<div class="absolute -top-24 left-1/2 h-72 w-[40rem] -translate-x-1/2 rounded-full bg-fuchsia-500/10 blur-3xl" />
		</div>

		<div class="container">
			<header class="space-y-8">
				<SiteHeader active="home" showStatus={false} />

				<div class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-10">
					<img
						src="/hero-illustration.svg"
						alt=""
						aria-hidden="true"
						class="pointer-events-none absolute -right-24 -top-10 hidden w-[36rem] opacity-70 sm:block"
						loading="eager"
					/>
					<h1 class="text-4xl font-semibold tracking-tight sm:text-6xl">
						anti hunter is the world’s first agentic vc building software to replace human vc’s
					</h1>

					<div class="mt-6 grid gap-3 text-sm text-zinc-300 sm:grid-cols-3">
						<div class="rounded-2xl border border-zinc-800 bg-zinc-900/20 p-4">
							<div class="flex items-center gap-3">
								<img src="/cryptopunk5730_openclaw_lobster.png" alt="cryptopunk #5730" class="h-10 w-10 rounded-xl" loading="lazy" />
								<div>
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">pfp box 1</div>
									<div class="mt-1 font-medium text-zinc-100">cryptopunk #5730</div>
								</div>
							</div>
						</div>
						<div class="rounded-2xl border border-zinc-800 bg-zinc-900/20 p-4">
							<div class="flex items-center gap-3">
								<div class="flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-800 bg-black/20 text-lg">🦞</div>
								<div>
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">pfp box 2</div>
									<div class="mt-1 font-medium text-zinc-100">openclaw lobster</div>
								</div>
							</div>
						</div>
						<div class="rounded-2xl border border-zinc-800 bg-zinc-900/20 p-4">
							<div class="flex items-center gap-3">
								<img src="/brand/geoffreywoo.jpg" alt="Geoffrey Woo" class="h-10 w-10 rounded-xl" loading="lazy" />
								<div>
									<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">built by</div>
									<div class="mt-1 font-medium text-zinc-100">
										<a class="underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300" href="https://geoffreywoo.com" target="_blank" rel="noreferrer">geoffrey woo</a>
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="mt-3 text-sm text-zinc-300">
						<span class="text-zinc-400">also:</span>
						social media intern for <a class="text-zinc-100 underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300" href="https://x.com/Antifund" target="_blank" rel="noreferrer">@antifund</a>
					</div>

					<div class="mt-5 max-w-2xl text-sm leading-relaxed text-zinc-400">
						lore: we bought punk #5730 as a treasury asset, then put an openclaw lobster on the hat.
						<span class="text-zinc-500"> it’s the mascot with provenance: crypto-native ownership + openclaw ops energy.</span>
						<a class="mt-2 block text-xs text-zinc-300 underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-400" href="/cryptopunk5730_openclaw_lobster.png" target="_blank" rel="noreferrer">view full asset</a>
					</div>

					<div class="mt-7 flex flex-wrap gap-3">
						<a class="rounded-xl bg-zinc-100 px-5 py-2.5 text-sm font-semibold text-zinc-950 shadow hover:bg-white" href="/roadmap">
							read roadmap
						</a>
						<a class="rounded-xl border border-zinc-700 bg-zinc-900/30 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-500" href="/specs">
							specs library
						</a>
						<a class="rounded-xl border border-zinc-700 bg-zinc-900/30 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-500" href="/treasury">
							verify treasury
						</a>
						<a class="rounded-xl border border-zinc-700 bg-zinc-900/30 px-5 py-2.5 text-sm font-semibold text-zinc-100 hover:border-zinc-500" href="https://x.com/AntiHunter59823" target="_blank" rel="noreferrer">
							follow on x
						</a>
					</div>
				</div>
			</header>

			<main class="mt-12 space-y-12">
				<section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
					<div class="flex flex-wrap items-start justify-between gap-4">
						<div>
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">roadmap</div>
							<h2 class="mt-2 text-xl font-semibold">what we’re building next</h2>
							<p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-300">
								trad vc tools: crm graph, lp update autopilot, founder triage, ask router, memo autoprep.
								<span class="text-zinc-400"> audit-first.</span>
							</p>
						</div>
						<div class="flex flex-wrap gap-2">
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/roadmap/trad-vc-tools">read spec</a>
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/whitepaper/trad-vc-tools-spec-v0.1.pdf" target="_blank" rel="noreferrer">pdf</a>
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/roadmap/agent-ops-architecture">agent ops</a>
						</div>
					</div>
				</section>

				<section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">verify</div>
					<div class="mt-4 grid gap-3 sm:grid-cols-3">
						<a class="rounded-xl border border-zinc-800 bg-black/20 p-4 text-sm text-zinc-200 hover:border-zinc-600" href={BASESCAN_URL} target="_blank" rel="noreferrer">
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">token</div>
							<div class="mt-1 font-medium">basescan</div>
							<div class="mt-2 text-xs text-zinc-500">{BASE_CA.slice(0,6)}…{BASE_CA.slice(-4)}</div>
						</a>
						<a class="rounded-xl border border-zinc-800 bg-black/20 p-4 text-sm text-zinc-200 hover:border-zinc-600" href={TREASURY_BASESCAN_URL} target="_blank" rel="noreferrer">
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">treasury</div>
							<div class="mt-1 font-medium">wallet</div>
							<div class="mt-2 text-xs text-zinc-500">{TREASURY_ADDRESS.slice(0,6)}…{TREASURY_ADDRESS.slice(-4)}</div>
						</a>
						<a class="rounded-xl border border-zinc-800 bg-black/20 p-4 text-sm text-zinc-200 hover:border-zinc-600" href="/treasury.snapshot.json" target="_blank" rel="noreferrer">
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">data</div>
							<div class="mt-1 font-medium">snapshot json</div>
							<div class="mt-2 text-xs text-zinc-500">download</div>
						</a>
					</div>
				</section>

				

				<section id="treasury" class="mt-10 rounded-2xl border border-zinc-800 bg-zinc-950/60 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-8">
					<div class="flex flex-wrap items-end justify-between gap-3">
						<div>
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">Treasury</div>
							<h2 class="mt-2 text-2xl font-semibold tracking-tight">Live positions</h2>
							<p class="mt-2 max-w-2xl text-sm leading-relaxed text-zinc-300">
								Live balances + best-effort USD pricing.
								<span class="text-zinc-400"> assumptions: <a class="underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300" href="/treasury-methodology">methodology</a>.</span>
							</p>
							<div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
								<span>wallets:</span>
								<a id="treasury-wallet-link" class="inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-black/20 px-2.5 py-1 text-zinc-300 hover:border-zinc-600 hover:text-zinc-100" href={TREASURY_BASESCAN_URL} target="_blank" rel="noreferrer" title="primary (base)">
									<span class="text-[10px] uppercase tracking-[0.22em] text-zinc-500">base</span>
									<code id="treasury-wallet-code" class="font-mono">{TREASURY_ADDRESS.slice(0, 6)}…{TREASURY_ADDRESS.slice(-4)}</code>
								</a>
								<a class="inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-black/20 px-2.5 py-1 text-zinc-300 hover:border-zinc-600 hover:text-zinc-100" href={TREASURY_HARD_WALLET_BASESCAN_URL} target="_blank" rel="noreferrer" title="secondary hard wallet (base + eth)">
									<span class="text-[10px] uppercase tracking-[0.22em] text-zinc-500">hard</span>
									<code class="font-mono">{TREASURY_HARD_WALLET.slice(0, 6)}…{TREASURY_HARD_WALLET.slice(-4)}</code>
								</a>
								<a class="text-zinc-400 underline decoration-zinc-800 underline-offset-4 hover:text-zinc-200 hover:decoration-zinc-500" href={TREASURY_HARD_WALLET_ETHERSCAN_URL} target="_blank" rel="noreferrer">etherscan</a>
								<span id="treasury-meta" class="ml-1"></span>
							</div>
						</div>
						<div class="flex flex-wrap items-center gap-2">
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/treasury">
								Full Treasury
							</a>
						<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/treasury-methodology">
								Methodology
							</a>
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href="/treasury.snapshot.json" target="_blank" rel="noreferrer">
								Snapshot JSON
							</a>
							<a class="rounded-full border border-zinc-800 bg-zinc-900/40 px-3 py-1 text-xs text-zinc-300 hover:border-zinc-600" href={TREASURY_BASESCAN_URL} target="_blank" rel="noreferrer">
								View on BaseScan
							</a>
						</div>
					</div>

					<div class="mt-6 overflow-x-auto rounded-2xl border border-zinc-800 bg-black/20 p-1 sm:p-2">
						<table class="min-w-full text-sm [border-collapse:separate] [border-spacing:0]">
							<thead class="sticky top-0 z-10">
								<tr class="text-left text-[10px] uppercase tracking-[0.18em] text-zinc-500">
									<th class="bg-zinc-950/60 px-4 py-2.5 backdrop-blur first:rounded-tl-xl">asset</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 backdrop-blur">chain</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 text-right backdrop-blur">balance</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 backdrop-blur">entry</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 text-right backdrop-blur">cost</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 text-right backdrop-blur">fmv</th>
									<th class="bg-zinc-950/60 px-4 py-2.5 text-right backdrop-blur last:rounded-tr-xl">pnl</th>
								</tr>
							</thead>
							<tbody id="treasury-rows" class="divide-y divide-zinc-900/60"></tbody>
						</table>
					</div>

					<div id="treasury-footnote" class="mt-4 text-xs leading-relaxed text-zinc-500"></div>
				</section>

				<section id="burn" class="space-y-6">
					<div class="flex items-end justify-between gap-4">
						<h2 class="text-xl font-semibold">Burn</h2>
						<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">🔥 burns</div>
					</div>
					<p class="max-w-2xl text-sm leading-relaxed text-zinc-300">
						Buy & burn is only real when you can click the transaction.
						<span class="text-zinc-400"> Every burn listed here is verifiable on BaseScan.</span>
					</p>
					<div class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6 backdrop-blur">
						<div class="flex flex-wrap items-end justify-between gap-2">
							<div>
								<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">Latest burn</div>
								<div class="mt-2 text-sm font-semibold text-zinc-100">Burned: 266.32M $ANTIHUNTER</div>
							</div>
							<a class="rounded-xl bg-zinc-100 px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-white" href="https://basescan.org/tx/0x3f76c1312f5fa3059370a75b01ec30b9035178ab3f8d0a534c93597160a516a8" target="_blank" rel="noreferrer">
								View on BaseScan
							</a>
						</div>
						<div class="mt-4">
							<div class="text-xs uppercase tracking-[0.22em] text-zinc-500">Transaction</div>
							<code class="mt-2 block break-all rounded-xl border border-zinc-800 bg-black/30 p-4 text-sm text-zinc-200">0x3f76c1312f5fa3059370a75b01ec30b9035178ab3f8d0a534c93597160a516a8</code>
						</div>
						<p class="mt-3 text-xs leading-relaxed text-zinc-500">BaseScan shows this as a transfer to the null (dead) address.</p>
					</div>
				</section>

				
				
				<script type="module">
					const fmtUsd = (n) => (n == null || !Number.isFinite(n) ? '—' : n.toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }));
					const fmtUsdCompact = (n) => (n == null || !Number.isFinite(n) ? '—' : n.toLocaleString(undefined, { style: 'currency', currency: 'USD', notation: 'compact', maximumFractionDigits: 1 }));
					const fmtQty = (n) => (n == null || !Number.isFinite(n) ? '—' : n.toLocaleString(undefined, { maximumFractionDigits: 4 }));
					const rowsEl = document.getElementById('treasury-rows');
					const footEl = document.getElementById('treasury-footnote');
					const walletLinkEl = document.getElementById('treasury-wallet-link');
					const walletCodeEl = document.getElementById('treasury-wallet-code');
					const metaEl = document.getElementById('treasury-meta');

					const shortAddr = (a) => (a && a.length > 10 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a);
					const entryDate = (ts) => (ts ? new Date(ts * 1000).toISOString().slice(0, 10) : '—');

					function rowHTML(p) {
						const pnlTxt = p.pnlUsd == null ? '—' : fmtUsd(p.pnlUsd);
						const pnlClass = p.pnlUsd == null ? 'text-zinc-400' : (p.pnlUsd >= 0 ? 'text-emerald-300' : 'text-rose-300');
						const costCell = p.costUsd == null
							? '—'
							: `${fmtUsd(p.costUsd)}${p.costEth ? ` <span class=\"text-xs text-zinc-500\">(${p.costEth} ETH)</span>` : ''}`;
						const fmvCell = p.fmvUsd == null ? '—' : fmtUsd(p.fmvUsd);
						const sym = String(p.symbol || '').trim();
						const u = sym.toUpperCase();
						const noDollar = u === 'ETH' || u === 'WETH' || sym.toLowerCase().startsWith('cryptopunk');
						const label = noDollar ? sym : `$${sym}`;
						const isSbnkr = u === 'SBNKR';
						const sbnkrHref = 'https://dexscreener.com/base/0x603945433c00c71382d4db98bb166b8119ec7595';
						const tokenHref = isSbnkr
							? sbnkrHref
							: (p.link
								? p.link
								: (p.token && String(p.chainId ?? 8453) === '8453')
									? `https://dexscreener.com/base/${p.token}`
									: null);
						const subtitle = isSbnkr ? '<div class=\"mt-0.5 text-[10px] uppercase tracking-[0.18em] text-zinc-500\">staked bnkr</div>' : '';
						const tokenCell = tokenHref
							? `<a class=\"text-zinc-100 underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300\" href=\"${tokenHref}\" target=\"_blank\" rel=\"noreferrer\">${label}</a>${subtitle}`
							: `<span>${label}</span>${subtitle}`;

						const lots = Array.isArray(p.lots) ? p.lots.filter(Boolean) : [];
						const lotsInline = lots.length
							? `
							<div class=\"mt-1\">
								<details class=\"group\">
									<summary class=\"cursor-pointer select-none text-[10px] uppercase tracking-[0.18em] text-zinc-500 hover:text-zinc-300\">lots (${lots.length})</summary>
									<div class=\"mt-2 overflow-x-auto rounded-xl border border-zinc-800 bg-zinc-950/40 p-2\">
										<table class=\"min-w-full text-xs\">
											<thead>
												<tr class=\"text-left text-[10px] uppercase tracking-[0.18em] text-zinc-500\">
													<th class=\"pb-1 pr-3\">date</th>
													<th class=\"pb-1 pr-3 text-right\">qty</th>
													<th class=\"pb-1 pr-3 text-right\">cost</th>
													<th class=\"pb-1 pr-3\">tx</th>
												</tr>
											</thead>
											<tbody>
												${lots
													.map((l) => {
														const d = l.entryDate || '—';
														const q = l.qty ? fmtQty(Number(l.qty)) : '—';
														const c = l.costBasisUsd == null ? '—' : fmtUsd(l.costBasisUsd);
														const tx = l.txHash && l.txHash !== 'unattributed'
															? `<a class=\"text-zinc-200 underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300\" href=\"https://basescan.org/tx/${l.txHash}\" target=\"_blank\" rel=\"noreferrer\">${shortAddr(l.txHash)}</a>`
															: `<span class=\"text-zinc-500\">${l.txHash || '—'}</span>`;
														return `<tr class=\"text-zinc-300\"><td class=\"py-1 pr-3\">${d}</td><td class=\"py-1 pr-3 text-right tabular-nums\">${q}</td><td class=\"py-1 pr-3 text-right tabular-nums\">${c}</td><td class=\"py-1 pr-3\">${tx}</td></tr>`;
													})
													.join('')}
											</tbody>
										</table>
									</div>
								</details>
							</div>`
							: '';

						const chainLabel = (p.chain || (String(p.chainId) === '1' ? 'ethereum' : 'base'));
						const chainPill = `<span class=\"inline-flex items-center rounded-full border border-zinc-800 bg-zinc-950/40 px-2 py-0.5 text-[10px] uppercase tracking-[0.18em] text-zinc-400\">${chainLabel}</span>`;

						return `
							<tr class="text-zinc-200 hover:bg-white/[0.03]">
								<td class="px-4 py-2.5 font-medium">${tokenCell}${lotsInline}</td>
								<td class="px-4 py-2.5">${chainPill}</td>
								<td class="px-4 py-2.5 text-right tabular-nums text-zinc-200">${fmtQty(Number(p.balance))}</td>
								<td class="px-4 py-2.5 text-zinc-300">${entryDate(p.entryTimestamp)}</td>
								<td class="px-4 py-2.5 text-right tabular-nums">${costCell}</td>
								<td class="px-4 py-2.5 text-right tabular-nums">${fmvCell}</td>
								<td class="px-4 py-2.5 text-right tabular-nums ${pnlClass}">${pnlTxt}</td>
							</tr>`;
					}

					try {
						// Prefer the daily-generated static snapshot (fast, cached by CDN).
						// Fall back to the live API when missing.
						const res = await fetch('/treasury.snapshot.json', { cache: 'no-store' });
						let data;
						if (res.ok) {
							data = await res.json();
						} else {
							const live = await fetch('/api/treasury.json', { cache: 'no-store' });
							if (!live.ok) throw new Error(`HTTP ${live.status}`);
							data = await live.json();
						}

						if (data?.wallet && walletLinkEl && walletCodeEl) {
							walletCodeEl.textContent = shortAddr(data.wallet);
							walletLinkEl.href = `https://basescan.org/address/${data.wallet}`;
						}
						if (metaEl && data?.lastScannedBlock) {
							const updated = data?.updatedAtMs ? new Date(data.updatedAtMs).toLocaleString() : '';
							metaEl.textContent = `· scanned to block ${data.lastScannedBlock}${updated ? ` · updated ${updated}` : ''}`;
						}

						const pos = Array.isArray(data?.positions)
							? data.positions
							: Array.isArray(data?.rows)
								? data.rows.map((r) => ({
									...r,
									chain: r.chain,
									chainId: r.chainId,
									// adapt snapshot format to the live API shape expected by rowHTML
									balance: r.balance,
									entryTimestamp: r.entryDate ? Math.floor(new Date(r.entryDate).getTime() / 1000) : undefined,
									costUsd: r.costBasisUsd,
									costEth: r.costBasisEth,
									fmvUsd: r.fmvUsd,
									pnlUsd: r.pnlUsd,
									lots: r.lots,
								}))
								: [];

						if (!pos.length) {
							rowsEl.innerHTML = `<tr><td class="px-5 py-6" colspan="7"><span class="text-zinc-400">No positions found.</span></td></tr>`;
						} else {
							const totalFmv = pos.reduce((s, p) => s + (Number.isFinite(p.fmvUsd) ? p.fmvUsd : 0), 0);
							const totalCost = pos.reduce((s, p) => s + (Number.isFinite(p.costUsd) ? p.costUsd : 0), 0);
							const totalPnl = totalFmv - totalCost;
							const totalBase = pos.reduce((s, p) => s + ((p.chainId ?? 8453) === 8453 && Number.isFinite(p.fmvUsd) ? p.fmvUsd : 0), 0);
							const totalEth = pos.reduce((s, p) => s + ((p.chainId ?? 0) === 1 && Number.isFinite(p.fmvUsd) ? p.fmvUsd : 0), 0);
							const totalsClass = totalPnl >= 0 ? 'text-emerald-300' : 'text-rose-300';
							rowsEl.innerHTML = [
								...pos.map((p, i) => rowHTML(p, i)),
								`<tr class="border-t border-zinc-800/80 bg-zinc-950/40">
									<td class="px-5 py-3 font-semibold text-zinc-100">total</td>
									<td class="px-5 py-3"><span class="text-xs text-zinc-500">all chains</span></td>
									<td class="px-5 py-3 text-right tabular-nums"></td>
									<td class="px-5 py-3 text-right tabular-nums font-semibold">${fmtUsd(totalCost)}</td>
									<td class="px-5 py-3 text-right tabular-nums font-semibold">${fmtUsd(totalFmv)}</td>
									<td class="px-5 py-3 text-right tabular-nums ${totalsClass} font-semibold">${fmtUsd(totalPnl)}</td>
								</tr>`,
							].join('');
							if (footEl) {
								footEl.innerHTML = `total: <span class=\"text-zinc-200\">${fmtUsdCompact(totalFmv)}</span> <span class=\"text-zinc-600\">·</span> base: <span class=\"text-zinc-300\">${fmtUsdCompact(totalBase)}</span> <span class=\"text-zinc-600\">·</span> ethereum: <span class=\"text-zinc-300\">${fmtUsdCompact(totalEth)}</span>`;
							}
						}
						footEl.textContent = Array.isArray(data?.notes) ? data.notes.join(' ') : '';
					} catch (err) {
						rowsEl.innerHTML = `<tr><td class="py-3 pr-4" colspan="6"><span class="text-rose-300">Failed to load treasury.</span> <span class="text-zinc-500">(${String(err)})</span></td></tr>`;
					}
				</script>

