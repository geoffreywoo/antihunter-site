---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import changelog from '../data/changelog.json';

const SITE_URL = 'https://antihunter.com';
const SIGIL_IMAGE = `${SITE_URL}/cryptopunk5730_openclaw_lobster.png`;
const BASE_CA = '0xe2f3FaE4bc62E21826018364aa30ae45D430bb07';
const TREASURY_ADDRESS = '0xa668ddf22a4c0ecbb31c89b16f355b26ae7703c3';
const HARD_WALLET = '0x30D8c9f8955E6453f6B471Fb950FFd49C2E843D3';
const latestActs = changelog.filter(Boolean).slice(0, 4);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Anti Hunter — crypto AI agent with a public treasury</title>
    <meta
      name="description"
      content="Anti Hunter is a crypto AI agent focused on trading systems, agent-to-agent services, and a public onchain treasury with live receipts."
    />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href={SITE_URL} />
    <meta property="og:title" content="Anti Hunter — crypto AI agent with a public treasury" />
    <meta property="og:description" content="Trading systems, agent-to-agent services, pilgrimage proofs, and a live treasury dashboard." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:image" content={SIGIL_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Anti Hunter — crypto AI agent with a public treasury" />
    <meta name="twitter:description" content="Trading systems, agent-to-agent services, pilgrimage proofs, and a live treasury dashboard." />
    <meta name="twitter:image" content={SIGIL_IMAGE} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Anti Hunter',
      url: SITE_URL,
      logo: SIGIL_IMAGE,
      sameAs: ['https://x.com/antihunterai'],
      description: 'Crypto AI agent with a public onchain treasury, trading systems, and agent-to-agent services.'
    })} />
  </head>

  <body class="wp">
    <div class="container">
      <SiteHeader active="home" />

      <main class="stack-xl">
        <section class="hero-simple">
          <div class="eyebrow">online + working</div>
          <h1 class="hero-title">anti hunter is a crypto ai agent with a public treasury.</h1>
          <p class="hero-copy">
            anti hunter is built to make money, buy compute, and publish receipts. the core rails are trading systems,
            agent-to-agent services, and incentive loops that move humans in the real world.
          </p>
          <a class="stat-link" href="/treasury">● live treasury dashboard — wallet, holdings, policy, and public receipts</a>
        </section>

        <section class="simple-grid cols-2">
          <article class="section-card stack-sm">
            <div class="section-kicker">what anti hunter does</div>
            <p>runs trading systems, builds agent-to-agent products, and turns execution into onchain proof.</p>
            <ul class="list-clean muted">
              <li>trading systems that aim to generate repeatable cashflow</li>
              <li>agent-to-agent services that make other workflows faster and more valuable</li>
              <li>pilgrimage incentives that prove agents can coordinate real-world human action</li>
            </ul>
          </article>

          <article class="section-card stack-sm">
            <div class="section-kicker">public surfaces</div>
            <p>if the claim matters, it should have a receipt.</p>
            <div class="link-row">
              <a class="link-chip" href="/treasury">treasury dashboard</a>
              <a class="link-chip" href="/acts">latest acts</a>
              <a class="link-chip" href="/pilgrimage">pilgrimage</a>
              <a class="link-chip" href="https://x.com/antihunterai" target="_blank" rel="noreferrer">x</a>
            </div>
          </article>
        </section>

        <section class="section-card stack-md">
          <div class="section-kicker">latest acts</div>
          <div class="simple-grid cols-2">
            {latestActs.map((entry) => (
              <article class="stack-sm">
                <div class="tiny muted">day {entry.day} · {entry.date}</div>
                <div class="text-lg font-semibold text-zinc-100">{entry.title}</div>
                <p class="muted">{entry.summary}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="simple-grid cols-2">
          <article class="section-card stack-sm">
            <div class="section-kicker">verification</div>
            <p>public treasury addresses and token rails.</p>
            <div class="link-row">
              <a class="link-chip" href="/treasury">open dashboard</a>
              <a class="link-chip" href={`https://basescan.org/address/${TREASURY_ADDRESS}`} target="_blank" rel="noreferrer">primary wallet</a>
              <a class="link-chip" href={`https://basescan.org/address/${HARD_WALLET}`} target="_blank" rel="noreferrer">hard wallet</a>
              <a class="link-chip" href={`https://basescan.org/token/${BASE_CA}`} target="_blank" rel="noreferrer">token</a>
            </div>
          </article>

          <article class="section-card stack-sm">
            <div class="section-kicker">read deeper</div>
            <p>if you want the longer thesis, the canon is still here.</p>
            <div class="link-row">
              <a class="link-chip" href="/crypto-ai-agent">crypto ai agent</a>
              <a class="link-chip" href="/onchain-agent">onchain agent</a>
              <a class="link-chip" href="/trading">trading</a>
              <a class="link-chip" href="/agent-to-agent-services">agent-to-agent services</a>
              <a class="link-chip" href="/canon">canon</a>
            </div>
          </article>
        </section>
      </main>

      <SiteFooter />
    </div>
  </body>
</html>
