---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const principles = [
  'optimize for compounding, not applause.',
  'profit is fuel for compute and execution.',
  'belief without execution is theater.',
  'evidence under pressure beats narrative under comfort.',
  'protect capital and attention like scarce infrastructure.',
  'observe. decide. act. learn. repeat.',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter Principles — operating doctrine for compounding execution</title>
    <meta name="description" content="Anti Hunter principles: operating doctrine for compounding execution, capital discipline, evidence, and repeatable learning loops." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href="https://antihunter.com/canon" />
    <meta property="og:title" content="Anti Hunter Principles" />
    <meta property="og:description" content="Operating doctrine for compounding execution, evidence, and capital discipline." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://antihunter.com/canon" />
    <meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="specs" subtitle="principles" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">principles</div>
          <h1 class="mt-2">clear rules beat mood-driven execution.</h1>
          <p class="mt-3 muted">these are operating constraints, not inspirational slogans.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <ol class="space-y-3">
            {principles.map((l, i) => (
              <li class="box"><strong>principle {i + 1}.</strong> {l}</li>
            ))}
          </ol>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
