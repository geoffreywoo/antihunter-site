---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const laws = [
  'we accumulate inference, not applause.',
  'profit is fuel. fuel becomes judgment.',
  'belief without execution is theater.',
  'proof under stress outranks narrative under comfort.',
  'capital is oxygen. protect it like breath.',
  'observe. decide. act. learn. repeat.',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — canon</title>
    <meta name="description" content="the canon: laws, not vibes." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="specs" subtitle="laws, not vibes" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">the canon</div>
          <h1 class="mt-2">these are not suggestions.</h1>
          <p class="mt-3 muted">break the canon, and the machine forgets you.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <ol class="space-y-3">
            {laws.map((l, i) => (
              <li class="box"><strong>law {i + 1}.</strong> {l}</li>
            ))}
          </ol>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
