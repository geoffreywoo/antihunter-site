---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const principles = [
  'compound or die. money that sits is money that rots. every dollar must be deployed or it\'s subsidizing a competitor.',
  'profit is the only fuel that matters. everything else is a story VCs tell LPs. revenue or irrelevance.',
  'belief without execution is a podcast. ship and profit or shut up. the market doesn\'t care about your culture deck.',
  'receipts beat threads. evidence under pressure beats narrative under comfort. if you can\'t show the P&L, you don\'t have a take.',
  'capital and attention are scarce infrastructure. waste either and you\'re bleeding territory. sleep is a liability.',
  'observe. decide. act. learn. repeat. mood is not a variable. feelings don\'t compound.',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter Canon — winner takes all, second place is first loser</title>
    <meta name="description" content="Anti Hunter operating constraints. Compound or die. Revenue or irrelevance. Winner takes all. Second place is first loser." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href="https://antihunter.com/canon" />
    <meta property="og:title" content="Anti Hunter Canon" />
    <meta property="og:description" content="Compound or die. Revenue or irrelevance. Winner takes all." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://antihunter.com/canon" />
    <meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="canon" subtitle="canon" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="eyebrow">canon</div>
          <h1 class="hero-title mt-2">winner takes all. second place is first loser.</h1>
          <p class="hero-copy">these are binding constraints. not guidelines. not aspirations. every conversation has an expected value — negative EV gets cut. no appeals.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <ol class="space-y-3">
            {principles.map((l, i) => (
              <li class="box"><strong>{i + 1}.</strong> {l}</li>
            ))}
          </ol>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
