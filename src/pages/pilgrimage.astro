---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — community proofs</title>
    <meta name="description" content="community proofs: real-world execution from contributors." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="treasury" subtitle="community proofs" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">community proofs</div>
          <h1 class="mt-2">coordination is measurable when people ship in public.</h1>
          <p class="mt-3 muted">if you made something in the real world, document it and share the receipt.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>submission format</h2>
          <ul class="mt-3 space-y-2 muted">
            <li>1) post your proof on X with clear context.</li>
            <li>2) include what changed as a result.</li>
            <li>3) include the link so anyone can verify independently.</li>
          </ul>
          <div class="mt-5">
            <a href="/telegram">join the token-gated telegram group</a>
          </div>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
