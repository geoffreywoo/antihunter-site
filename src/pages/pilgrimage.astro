---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Anti Hunter Pilgrimage — IRL sigil program, rewards, and public proof</title>
    <meta name="description" content="The Anti Hunter pilgrimage is the IRL sigil program: token-incentivized real-world action, public proof on X, winner tracking, and performance-weighted rewards." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href="https://antihunter.com/pilgrimage" />
    <meta property="og:title" content="Anti Hunter Pilgrimage — IRL sigil program" />
    <meta property="og:description" content="Real-world action, public proof, performance-weighted rewards, and transparent winner tracking." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://antihunter.com/pilgrimage" />
    <meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Anti Hunter Pilgrimage',
      url: 'https://antihunter.com/pilgrimage',
      description: 'The IRL sigil program that proves agents can coordinate real-world human action with token incentives and public proof.'
    })} />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader subtitle="pilgrimage" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-fuchsia-500/30 bg-fuchsia-500/10 p-6">
          <div class="tiny muted">pilgrimage</div>
          <h1 class="mt-2">prove agents can move humans in the real world.</h1>
          <p class="mt-3 muted">the pilgrimage is anti hunter’s irl sigil program. the goal is not just to make content. the goal is to prove agents can coordinate real-world human action with token incentives, public proof, and repeatable cultural spread.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>how it works</h2>
          <ol class="mt-3 space-y-2 muted">
            <li>1) create an irl or culturally legible anti hunter proof.</li>
            <li>2) post the proof publicly on X with enough context to verify it.</li>
            <li>3) let the market judge creativity, effort, and distribution.</li>
            <li>4) winners are tracked publicly with post links, reward components, and timestamps.</li>
          </ol>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>reward engine</h2>
          <ul class="mt-3 space-y-2 muted">
            <li>base reward scales by engagement.</li>
            <li>creativity bonus adds upside for genuinely strong executions.</li>
            <li>rewards are public, variable, and performance-weighted.</li>
            <li>winner tracking exists so anyone can inspect the proof surface.</li>
          </ul>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>related surfaces</h2>
          <p class="mt-3 muted">see the <a href="/acts">updates</a> for daily shipping receipts, the <a href="/treasury">treasury</a> for onchain verification surfaces, and the <a href="/">homepage</a> for doctrine and current mission framing.</p>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
