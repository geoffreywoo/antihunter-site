---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import winnerPosts from '../data/sigil-winners.json';

function tweetIdFromUrl(url: string) {
  const m = String(url || '').match(/\/status\/(\d+)/i);
  return m?.[1] ?? null;
}

function toOfficialEmbedUrl(url: string) {
  const id = tweetIdFromUrl(url);
  if (!id) return null;
  return `https://platform.twitter.com/embed/Tweet.html?id=${id}&theme=dark&dnt=true`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — community proofs</title>
    <meta name="description" content="community proofs: real-world execution from contributors." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="treasury" subtitle="community proofs" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">community proofs</div>
          <h1 class="mt-2">coordination is measurable when people ship in public.</h1>
          <p class="mt-3 muted">if you made something in the real world, document it and share the receipt.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>submission format</h2>
          <ul class="mt-3 space-y-2 muted">
            <li>1) post your proof on X with clear context.</li>
            <li>2) include what changed as a result.</li>
            <li>3) include the link so anyone can verify independently.</li>
          </ul>
          <div class="mt-5">
            <a href="/telegram">join the token-gated telegram group</a>
          </div>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">reward engine + winner tracking</div>
          <h2 class="mt-2">sigil rewards are variable, performance-weighted, and publicly tracked.</h2>
          <ul class="mt-3 space-y-2 muted">
            <li><strong>base reward:</strong> scales by engagement (views + likes), up to <strong>100,000,000 $antihunter</strong> at <strong>1,000,000 views</strong>.</li>
            <li><strong>creativity bonus:</strong> variable upside up to <strong>20,000,000 $antihunter</strong> for high-creativity executions.</li>
            <li><strong>max per proof:</strong> hard cap of <strong>120,000,000 $antihunter</strong>.</li>
            <li><strong>winner tracking:</strong> each winning proof is logged with handle, post URL, reward components, and timestamp for transparent announcements.</li>
          </ul>
          <p class="mt-4 muted">announcements are posted on X and mirrored in holder channels so the scoreboard stays auditable.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">past winners</div>
          <h2 class="mt-2">verified irl sigil winners (embedded)</h2>
          <p class="mt-3 muted">this wall shows prior verified winner posts directly from X.</p>
          <div class="mt-5 grid gap-6 lg:grid-cols-2">
            {winnerPosts.map((post) => {
              const embedUrl = toOfficialEmbedUrl(post.url);
              return (
                <div class="space-y-2 rounded-xl border border-zinc-800 bg-zinc-950/60 p-3">
                  {embedUrl ? (
                    <iframe
                      title={`winner embed ${post.label ?? ''}`}
                      src={embedUrl}
                      class="h-[650px] w-full rounded-lg border border-zinc-800 bg-black"
                      loading="lazy"
                      referrerpolicy="no-referrer"
                    />
                  ) : (
                    <div class="rounded-lg border border-zinc-800 bg-black/40 p-4 text-sm text-zinc-400">embed unavailable for this post id</div>
                  )}
                  <a class="text-sm text-zinc-300 underline decoration-zinc-700 underline-offset-4 hover:decoration-zinc-300" href={post.url} target="_blank" rel="noreferrer">
                    open winner post on x ↗
                  </a>
                </div>
              );
            })}
          </div>
          <p class="mt-4 text-xs text-zinc-500">using official X embed iframes. if your browser blocks third-party embeds, use direct links.</p>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
