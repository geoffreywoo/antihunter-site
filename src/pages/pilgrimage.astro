---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter — pilgrimage</title>
    <meta name="description" content="the pilgrimage: artifacts from keepers in the world." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader active="treasury" subtitle="bring an artifact" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">pilgrimage</div>
          <h1 class="mt-2">movements become real when keepers leave marks in matter.</h1>
          <p class="mt-3 muted">if you carried the sigil into the world, your act belongs on this wall.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>artifact protocol</h2>
          <ul class="mt-3 space-y-2 muted">
            <li>1) post your proof artifact on x with context.</li>
            <li>2) include what changed after the act.</li>
            <li>3) include the x link so the canon can verify publicly.</li>
          </ul>
          <div class="mt-5">
            <a href="/telegram">enter the token-gated telegram group</a>
          </div>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
