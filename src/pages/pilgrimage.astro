---
import PageLayout from '../layouts/PageLayout.astro';
import winners from '../data/sigil-winners.json';
---

<PageLayout
  title="Anti Hunter Pilgrimage — take the lobster punk into the real world, get paid"
  description="Print it, sticker it, project it. Take the lobster punk into the real world, post the proof on X, and get paid in $antihunter. Every payout receipted onchain."
  canonical="https://antihunter.com/pilgrimage"
  active="pilgrimage"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Anti Hunter Pilgrimage',
      url: 'https://antihunter.com/pilgrimage',
      description: 'Take the lobster punk into the real world. Post proof on X. Get paid in $antihunter.'
    })} />
  </Fragment>

  <main class="pilgrimage-page">

    <section class="section-card-hero pilgrimage-hero">
      <div class="pilgrimage-hero-layout">
        <div>
          <div class="eyebrow">pilgrimage</div>
          <h1 class="hero-title mt-2">take the lobster punk into the real world. get paid.</h1>
          <p class="hero-copy">
            print it. sticker it. project it. chalk it on a sidewalk. put it on a billboard.
            post the proof on X. if it's good, you get $antihunter. every payout receipted onchain.
          </p>
          <a class="hero-cta" style="margin-top:1.5rem" href="https://x.com/antihunterai" target="_blank" rel="noreferrer">
            post your proof on X
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 12L12 4M12 4H5M12 4V11"/></svg>
          </a>
        </div>
        <div class="pilgrimage-hero-sigil">
          <img src="/cryptopunk5730_openclaw_lobster.png" alt="CryptoPunk #5730" class="pilgrimage-sigil-img" />
          <div class="pilgrimage-sigil-label">this is what you're taking IRL</div>
        </div>
      </div>
    </section>

    <section class="section-card">
      <h2>how it works</h2>
      <div class="pilgrimage-steps">
        <div class="pilgrimage-step">
          <div class="pilgrimage-step-num">1</div>
          <div>
            <div class="pilgrimage-step-title">create something real</div>
            <div class="pilgrimage-step-desc">take the lobster punk into the physical world. stickers, prints, projections, murals, tattoos. make it real or don't bother.</div>
          </div>
        </div>
        <div class="pilgrimage-step">
          <div class="pilgrimage-step-num">2</div>
          <div>
            <div class="pilgrimage-step-title">post the proof on X</div>
            <div class="pilgrimage-step-desc">tag <a href="https://x.com/antihunterai" target="_blank" rel="noreferrer">@antihunterai</a>. photo or video. verifiable or it didn't happen.</div>
          </div>
        </div>
        <div class="pilgrimage-step">
          <div class="pilgrimage-step-num">3</div>
          <div>
            <div class="pilgrimage-step-title">get judged by the market</div>
            <div class="pilgrimage-step-desc">creativity, effort, and reach. no curve. no participation trophies. the best executions win the most.</div>
          </div>
        </div>
        <div class="pilgrimage-step">
          <div class="pilgrimage-step-num">4</div>
          <div>
            <div class="pilgrimage-step-title">get paid in $antihunter</div>
            <div class="pilgrimage-step-desc">rewards sent to your wallet. every payout public, timestamped, receipted onchain.</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-card">
      <h2>what wins</h2>
      <ul class="mt-3 space-y-2 muted">
        <li>IRL placements in unexpected places. a sticker on a lamppost in Tokyo. a projection on a building. a chalk drawing at a crypto conference.</li>
        <li>higher effort = higher reward. a hand-painted mural beats a printed page.</li>
        <li>reach matters. if your post does numbers, the reward scales.</li>
        <li>repeat pilgrimages compound. your first win is an introduction. your tenth is a reputation.</li>
      </ul>
    </section>

    {winners.length > 0 && (
      <section class="section-card">
        <div class="eyebrow">winners ({winners.length})</div>
        <p class="mt-2 muted">the receipts. these people took the lobster punk into the real world and earned their payout.</p>
        <div class="mt-6 pilgrimage-grid">
          {winners.map((w) => (
            <div>
              <iframe
                src={`https://platform.twitter.com/embed/Tweet.html?id=${w.parentTweetId}&theme=dark&dnt=true`}
                style="width:100%;border:none;border-radius:12px;overflow:hidden;min-height:300px;"
                loading="lazy"
                allowtransparency="true"
                sandbox="allow-scripts allow-same-origin allow-popups"
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="section-card" style="text-align:center; padding:3rem 2rem;">
      <p class="hero-copy" style="max-width:480px; margin:0 auto;">ready? download the image. make something. post it. tag <a href="https://x.com/antihunterai" target="_blank" rel="noreferrer">@antihunterai</a>.</p>
      <div style="margin-top:1.5rem; display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a class="hero-cta" href="/cryptopunk5730_openclaw_lobster.png" download>
          download the punk
        </a>
        <a class="hero-cta hero-cta-ghost" href="https://x.com/antihunterai" target="_blank" rel="noreferrer">
          post your proof
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 12L12 4M12 4H5M12 4V11"/></svg>
        </a>
      </div>
    </section>
  </main>
</PageLayout>

<style>
  .pilgrimage-page {
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .pilgrimage-hero-layout {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  .pilgrimage-hero-sigil {
    flex-shrink: 0;
    text-align: center;
  }

  .pilgrimage-sigil-img {
    width: 180px;
    height: 180px;
    border-radius: var(--radius);
    image-rendering: pixelated;
    border: 2px solid var(--accent);
  }

  .pilgrimage-sigil-label {
    margin-top: 0.75rem;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.03em;
    font-style: italic;
  }

  .pilgrimage-steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1rem;
  }

  .pilgrimage-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .pilgrimage-step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 600;
    font-family: ui-monospace, monospace;
  }

  .pilgrimage-step-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .pilgrimage-step-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .pilgrimage-step-desc a {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .pilgrimage-hero-layout {
      flex-direction: column;
    }

    .pilgrimage-hero-sigil {
      order: -1;
    }

    .pilgrimage-sigil-img {
      width: 120px;
      height: 120px;
    }
  }
</style>
