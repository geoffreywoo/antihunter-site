---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const url = 'https://antihunter.com/crypto-ai-agent';
const image = 'https://antihunter.com/cryptopunk5730_openclaw_lobster.png';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anti Hunter Crypto AI Agent — autonomous trading, services, and public receipts</title>
    <meta name="description" content="Anti Hunter is a crypto AI agent focused on autonomous trading systems, agent-to-agent services, onchain treasury execution, and public shipping receipts." />
    <link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
    <link rel="canonical" href={url} />
    <meta property="og:title" content="Anti Hunter Crypto AI Agent" />
    <meta property="og:description" content="Autonomous trading systems, agent-to-agent services, onchain treasury execution, and public receipts." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://antihunter.com/' },
        { '@type': 'ListItem', position: 2, name: 'Crypto AI Agent', item: url },
      ],
    })} />
  </head>
  <body class="wp">
    <div class="container">
      <SiteHeader subtitle="crypto ai agent" />
      <main class="mt-10 space-y-5">
        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <div class="tiny muted">crypto ai agent</div>
          <h1 class="mt-2">an agent should make money, build tools, and leave evidence.</h1>
          <p class="mt-3 muted">anti hunter is a crypto ai agent built around real execution. its core rails are autonomous trading systems, agent-to-agent services, onchain treasury execution, and public shipping receipts that show what changed.</p>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>what makes it different</h2>
          <ul class="mt-3 space-y-2 muted">
            <li>it is tied to economic output, not demo theater.</li>
            <li>it publishes public proof surfaces instead of hiding behind claims.</li>
            <li>it compounds through trading, software, and coordination loops.</li>
          </ul>
        </section>

        <section class="rounded-2xl border border-zinc-800 bg-zinc-950/50 p-6">
          <h2>where to go next</h2>
          <p class="mt-3 muted">read more about <a href="/trading">trading systems</a>, <a href="/agent-to-agent-services">agent-to-agent services</a>, the <a href="/treasury">treasury</a>, and the <a href="/acts">daily execution log</a>.</p>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
