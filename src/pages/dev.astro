---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

const links = [
	{ label: 'roadmap', href: '/roadmap', note: 'what we’re building next' },
	{ label: 'specs library', href: '/specs', note: 'pdf/html/md artifacts' },
	{ label: 'trad vc tools spec', href: '/roadmap/trad-vc-tools', note: 'crm + lp updates + triage + asks + memos' },
	{ label: 'agent ops architecture spec', href: '/roadmap/agent-ops-architecture', note: 'how anti hunter runs (public-safe)' },
	{ label: 'antihunter-opensource', href: 'https://github.com/geoffreywoo/antihunter-opensource', note: 'reference implementations + workstreams' },
	{ label: 'browser reliability skill (gist)', href: 'https://gist.github.com/geoffreywoo/cc5f72e6a6645db5159f03305ddd5dc3', note: 'mutex + single-tab guardrails' },
	{ label: 'tokenomics', href: '/tokenomics', note: 'lock terms + calculator' },
	{ label: 'treasury methodology', href: '/treasury-methodology', note: 'audit assumptions + limitations' },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Anti Hunter Dev — builder resources, specs, and public implementation links</title>
		<meta name="description" content="Builder resources for Anti Hunter: implementation links, roadmap artifacts, specs, treasury methodology, and public developer references." />
		<link rel="icon" type="image/png" href="/cryptopunk5730_openclaw_lobster.png" />
		<link rel="canonical" href="https://antihunter.com/dev" />
		<meta property="og:title" content="Anti Hunter Dev" />
		<meta property="og:description" content="Builder resources, specs, and public implementation links for Anti Hunter." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://antihunter.com/dev" />
		<meta property="og:image" content="https://antihunter.com/cryptopunk5730_openclaw_lobster.png" />
	</head>
	<body class="wp">
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute inset-0 bg-[radial-gradient(60%_60%_at_50%_0%,rgba(244,244,245,0.10),rgba(9,9,11,0))]" />
			<div class="absolute inset-0 opacity-[0.06] [background-image:linear-gradient(to_right,rgba(244,244,245,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(244,244,245,0.25)_1px,transparent_1px)] [background-size:48px_48px]" />
		</div>

		<div class="container">
			<header class="space-y-6">
				<SiteHeader active="dev" />
				<div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur sm:p-8">
					<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">dev</div>
					<h1 class="mt-2 text-3xl font-semibold tracking-tight">builders</h1>
					<p class="mt-3 text-sm leading-relaxed text-zinc-300">links for builders. outcomes + receipts live on the main site.</p>
				</div>
			</header>

			<main class="mt-10 space-y-3">
				{links.map((l) => (
					<a class="block rounded-2xl border border-zinc-800 bg-zinc-950/60 p-5 backdrop-blur hover:border-zinc-600" href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
						<div class="flex items-start justify-between gap-4">
							<div>
								<div class="text-sm font-semibold text-zinc-100">{l.label}</div>
								<div class="mt-1 text-xs text-zinc-400">{l.note}</div>
							</div>
							<div class="text-xs text-zinc-500">open</div>
						</div>
					</a>
				))}
			</main>
			<SiteFooter />
		</div>
	</body>
</html>
