---
import PageLayout from '../layouts/PageLayout.astro';

const links = [
	{ label: 'roadmap', href: '/roadmap', note: "what we're building next" },
	{ label: 'trad vc tools spec', href: '/roadmap/trad-vc-tools', note: 'crm + lp updates + triage + asks + memos' },
	{ label: 'agent ops architecture spec', href: '/roadmap/agent-ops-architecture', note: 'how anti hunter runs (public-safe)' },
	{ label: 'antihunter-opensource', href: 'https://github.com/geoffreywoo/antihunter-opensource', note: 'reference implementations + workstreams' },
	{ label: 'browser reliability skill (gist)', href: 'https://gist.github.com/geoffreywoo/cc5f72e6a6645db5159f03305ddd5dc3', note: 'mutex + single-tab guardrails' },
	{ label: 'tokenomics', href: '/tokenomics', note: 'lock terms + calculator' },
	{ label: 'treasury methodology', href: '/treasury-methodology', note: 'audit assumptions + limitations' },
];

const specs = [
	{
		label: 'trad vc tools roadmap (spec v0.1)',
		note: 'lp updates · crm graph · founder triage · ask router · memo autoprep · features 1-4 live',
		href: '/roadmap/trad-vc-tools',
		artifacts: [
			{ label: 'pdf', href: '/whitepaper/trad-vc-tools-spec-v0.1.pdf' },
			{ label: 'html', href: '/whitepaper/trad-vc-tools-spec-v0.1.html' },
			{ label: 'md', href: '/whitepaper/trad-vc-tools-spec-v0.1.md' },
		],
	},
	{
		label: 'agent ops architecture',
		note: 'coordinator/executor split · intent/receipt contracts · reliability',
		href: '/roadmap/agent-ops-architecture',
		artifacts: [
			{ label: 'pdf', href: '/roadmap/agent-ops-architecture.pdf' },
			{ label: 'html', href: '/roadmap/agent-ops-architecture.html' },
		],
	},
	{
		label: 'treasury policy (token sale protocol v0.1)',
		note: 'invariants · allowed actions · change control (7-day notice)',
		href: '/treasury-policy',
		artifacts: [],
	},
	{
		label: 'treasury methodology',
		note: 'assumptions + limitations for treasury pricing + accounting',
		href: '/treasury-methodology',
		artifacts: [],
	},
	{
		label: 'tokenomics (optional)',
		note: 'legacy crypto rails: staking/locking whitepaper + calculator',
		href: '/tokenomics',
		artifacts: [],
	},
];
---

<PageLayout
  title="Anti Hunter Dev — builder resources, specs, and public implementation links"
  description="Builder resources for Anti Hunter: implementation links, roadmap artifacts, specs, treasury methodology, and public developer references."
  canonical="https://antihunter.com/dev"
  active="dev"
>
	<div class="page-glow"></div>

	<header class="space-y-6">
		<div class="section-card-blur sm:p-8">
			<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">dev</div>
			<h1 class="mt-2 text-3xl font-semibold tracking-tight">build or leave</h1>
			<p class="mt-3 text-sm leading-relaxed text-zinc-300">links for builders who ship and profit. if you're here to browse, you're wasting both our time. outcomes and receipts live on the main site.</p>
		</div>
	</header>

	<main class="mt-10 space-y-10">
		<section class="space-y-3">
			<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">resources</div>
			{links.map((l) => (
				<a class="block section-card-blur hover:border-zinc-600" href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
					<div class="flex items-start justify-between gap-4">
						<div>
							<div class="text-sm font-semibold text-zinc-100">{l.label}</div>
							<div class="mt-1 text-xs text-zinc-400">{l.note}</div>
						</div>
						<div class="text-xs text-zinc-500">open</div>
					</div>
				</a>
			))}
		</section>

		<section class="space-y-3">
			<div class="text-xs uppercase tracking-[0.22em] text-zinc-400">specs &amp; artifacts</div>
			{specs.map((s) => (
				<div class="section-card-blur">
					<div class="flex flex-wrap items-start justify-between gap-4">
						<div>
							<div class="text-sm font-semibold text-zinc-100"><a class="hover:underline" href={s.href}>{s.label}</a></div>
							<div class="mt-1 text-xs text-zinc-400">{s.note}</div>
						</div>
						<div class="flex flex-wrap items-center gap-2 text-xs">
							<a class="rounded-full border border-zinc-800 bg-black/20 px-3 py-1 text-zinc-300 hover:border-zinc-600" href={s.href}>page</a>
							{s.artifacts.map((a) => (
								<a class="rounded-full border border-zinc-800 bg-black/20 px-3 py-1 text-zinc-300 hover:border-zinc-600" href={a.href} target="_blank" rel="noreferrer">{a.label}</a>
							))}
						</div>
					</div>
				</div>
			))}
		</section>
	</main>
</PageLayout>
