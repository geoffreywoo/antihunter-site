---
const {
	active = '',
	showStatus = false,
	subtitle = '',
} = Astro.props as {
	active?: 'home' | 'roadmap' | 'specs' | 'treasury' | 'dev' | '';
	showStatus?: boolean;
	subtitle?: string;
};

const nav = [
	{ label: 'roadmap', href: '/roadmap', key: 'roadmap' },
	{ label: 'specs', href: '/specs', key: 'specs' },
	{ label: 'treasury', href: '/treasury', key: 'treasury' },
	{ label: 'dev', href: '/dev', key: 'dev' },
] as const;

function pillClass(_key: string) {
	// legacy tailwind pill helper (kept to avoid churn; unused in ascii-whitepaper mode)
	return '';
}
---

<div class="site-header">
	<div class="brand">
		<a href="/" class="brand">
			<img src="/cryptopunk5730_openclaw_lobster.png" alt="anti hunter pfp" loading="eager" />
			<div>
				<div class="brand-title">anti hunter</div>
				{subtitle ? <div class="tiny muted">{subtitle}</div> : <div class="tiny muted">agentic vc</div>}
			</div>
		</a>
	</div>
	<nav class="nav tiny">
		{nav.map((n) => (
			<a href={n.href}>[{n.label}]</a>
		))}
		<a href="https://x.com/AntiHunter59823" target="_blank" rel="noreferrer">[x]</a>
	</nav>
</div>
<hr class="rule" />
