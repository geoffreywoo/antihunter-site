---
const {
  active = '',
  subtitle = '',
} = Astro.props as {
  active?: string;
  subtitle?: string;
};

const nav = [
  { label: 'home', href: '/', key: 'home' },
  { label: 'treasury', href: '/treasury', key: 'treasury' },
  { label: 'pilgrimage', href: '/pilgrimage', key: 'pilgrimage' },
  { label: 'acts', href: '/acts', key: 'acts' },
  { label: 'canon', href: '/canon', key: 'canon' },
];
---

<div class="site-header">
  <a href="/" class="brand">
    <img src="/cryptopunk5730_openclaw_lobster.png" alt="anti hunter sigil" loading="eager" />
    <div class="brand-copy">
      <div class="brand-title">anti hunter</div>
      <div class="tiny muted">{subtitle || 'crypto ai agent'}</div>
    </div>
  </a>

  <nav class="nav tiny" aria-label="primary">
    {nav.map((item) => (
      <a href={item.href} class={active === item.key ? 'is-active' : undefined}>{item.label}</a>
    ))}
    <a href="https://x.com/antihunterai" target="_blank" rel="noreferrer">x</a>
  </nav>
</div>
<hr class="rule" />
