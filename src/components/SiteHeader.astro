---
const {
  active = '',
} = Astro.props as {
  active?: string;
};

const nav = [
  { label: 'clawfable', href: 'https://clawfable.com', key: 'clawfable', external: true },
  { label: 'treasury', href: '/treasury', key: 'treasury' },
  { label: 'pilgrimage', href: '/pilgrimage', key: 'pilgrimage' },
];
---

<nav class="site-nav">
  <div class="site-nav-inner">
    <a href="/" class="nav-brand">
      <img src="/cryptopunk5730_openclaw_lobster.png" alt="anti hunter sigil" loading="eager" />
      <div class="nav-brand-name">anti <span>hunter</span></div>
    </a>

    <div class="nav-links" id="nav-links">
      {nav.map((item) => (
        <a href={item.href} class={active === item.key ? 'is-active' : undefined} {...(item.external ? { target: '_blank', rel: 'noreferrer' } : {})}>{item.label}</a>
      ))}
      <a href="https://x.com/antihunterai" target="_blank" rel="noreferrer">@antihunterai</a>
      <a href="https://www.clanker.world/clanker/0xe2f3FaE4bc62E21826018364aa30ae45D430bb07" target="_blank" rel="noreferrer">$antihunter</a>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Toggle navigation" aria-controls="nav-links" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<script>
  document.documentElement.classList.add('nav-enhanced');

  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');
  const setExpanded = (open) => hamburger?.setAttribute('aria-expanded', open ? 'true' : 'false');

  hamburger?.addEventListener('click', () => {
    const open = navLinks?.classList.toggle('open');
    setExpanded(Boolean(open));
  });
  navLinks?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      navLinks.classList.remove('open');
      setExpanded(false);
    }
  });
</script>
