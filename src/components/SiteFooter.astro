		<nav class="flex flex-wrap items-center gap-3">
			{links.map((l) => (
				<a class="text-zinc-400 hover:text-zinc-200" href={l.href}>{l.label}</a>
			))}
			<a class="text-zinc-400 hover:text-zinc-200" href="https://x.com/AntiHunter59823" target="_blank" rel="noreferrer">x</a>
		</nav>
	</div>
</footer>
